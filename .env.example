# Supabase Credentials Configuration for Family Synchronization
# Create your free project at https://supabase.com
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Suporte Jira (Edge Function) ───────────────────────────────────────────
# As credenciais do Jira (JIRA_DOMAIN, JIRA_EMAIL, JIRA_API_TOKEN) são
# Secrets do Supabase e NÃO ficam neste arquivo. Configure via:
#   supabase secrets set JIRA_DOMAIN=seu-dominio.atlassian.net
#   supabase secrets set JIRA_EMAIL=seu-email@exemplo.com
#   supabase secrets set JIRA_API_TOKEN=seu_token_gerado
