# Server Configuration
PORT=3000

# Allowed CORS Origins (comma-separated, or * to allow all for testing)
# Example: http://localhost:5173,https://meuapp.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Destination Email (integrated with your Jira Service Management)
SUPPORT_EMAIL_DEST=suporte.meuapp@gmail.com

# SMTP Server Configurations (for sending emails silently)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email-smtp@gmail.com
SMTP_PASS=sua-senha-de-aplicativo-ou-token
